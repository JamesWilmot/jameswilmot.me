---
import GitHubLink from './links/github.astro';
import dayjs from 'dayjs';

import advancedFormat from 'dayjs/plugin/advancedFormat';

dayjs.extend(advancedFormat);


const buildDate = dayjs()



---


<footer>
  <span>
    &copy; {buildDate.format("YYYY")} James Wilmot. 
    <GitHubLink href="https://github.com/JamesWilmot/jameswilmot.me">JamesWilmot/jameswilmot.me</GitHubLink>
      <br />
    Powered by <a href="https://astro.build" rel="noopener">Astro</a>.
    Derived from a template by <a href="https://www.twitter.com/Charca" rel="noopener">Maxi Ferreira</a>. <br /> <br />
    <i>Last updated:</i> <time datetime={buildDate}>{buildDate.format("dddd, Do MMMM YYYY")}</time>
  </span>
</footer>

<style>
  footer {
    container-type: inline-size;
    color: var(--text-secondary);
    font-size: .8em;
    margin: 1em auto;
    max-width: 1400px;
    padding: 1em 2em;
    text-align: center;
    width: 100%;
    @container (width < 300px ) {
    }
  }

</style>
