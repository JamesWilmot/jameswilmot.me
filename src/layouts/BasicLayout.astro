---
import BaseHead from '../components/BaseHead.astro';

export interface Props {
  title: string;
  description: string;
  current: string;
}
const { title, description, current } = Astro.props;
---
<html lang="en">
<head>
  <BaseHead title={title} description={description} current={current} />
</head>
<body>
  <div class="layout">
    <main>
      <slot />
    </main>

  </div>
</body>
</html>

<style>
  body {
    padding: 0;
    margin: 0;
  }
  .layout {
  }

  main {
  }
</style>
